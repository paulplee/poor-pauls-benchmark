# Poor Paul's Benchmark — environment configuration
# Copy this file to .env and fill in your values.

# Hugging Face API token (get one at https://huggingface.co/settings/tokens)
HF_TOKEN=

# Directory where downloaded GGUF models are stored (default: ./models)
# PPB_MODELS_DIR=./models

# Path to llama-bench binary (optional, overrides default)
# PPB_LLAMA_BENCH=/usr/local/bin/llama-bench

# Path to llama-server binary (optional, overrides default)
# PPB_LLAMA_SERVER=/usr/local/bin/llama-server
